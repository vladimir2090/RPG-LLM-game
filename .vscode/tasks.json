{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build game",
            "type": "shell",
            "command": "/usr/bin/bash",
            "args": [
                "-lc",
                "mkdir -p \"${workspaceFolder}/build\" && /usr/bin/g++ -std=c++17 -g -O0 \"${workspaceFolder}/main.cpp\" -I\"${workspaceFolder}/SDL3-3.4.4/include\" -L\"${workspaceFolder}/SDL3-3.4.4/build\" -Wl,-rpath,\"${workspaceFolder}/SDL3-3.4.4/build\" -lSDL3 -o \"${workspaceFolder}/build/game\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the game from main.cpp and link against the locally built SDL3"
        },
        {
            "label": "run game",
            "type": "shell",
            "command": "/usr/bin/bash",
            "args": [
                "-lc",
                "LD_LIBRARY_PATH=\"${workspaceFolder}/SDL3-3.4.4/build${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}\" \"${workspaceFolder}/build/game\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "build game",
            "problemMatcher": []
        }
    ]
}
