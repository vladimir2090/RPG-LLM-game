{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build game",
            "type": "shell",
            "command": "/usr/bin/bash",
            "args": [
                "-lc",
                "cmake -S \"${workspaceFolder}\" -B \"${workspaceFolder}/build\" && cmake --build \"${workspaceFolder}/build\" -j"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Configure and build the game with CMake"
        },
        {
            "label": "run game",
            "type": "shell",
            "command": "/usr/bin/bash",
            "args": [
                "-lc",
                "LD_LIBRARY_PATH=\"${workspaceFolder}/SDL3-3.4.4/build:${workspaceFolder}/SDL_image/build${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}\" \"${workspaceFolder}/build/game\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "build game",
            "problemMatcher": []
        }
    ]
}
